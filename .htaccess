# Beget / shared hosting: document root = папка ooofix-xmlupd-cloud (не public/)
DirectoryIndex public/index.php

# Версию PHP 8.1+ задайте в панели Beget для каталога market/ooofix-xmlupd-cloud

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^$ public/index.php [L]
    RewriteRule ^(.+)$ public/$1 [L]
</IfModule>
